ecotron.co.in, www.ecotron.co.in {
    tls internal
    reverse_proxy app:3000
    encode gzip
}

# Use HTTP for the internal connection (Cloudflare will handle HTTPS)
http://trading.ecotron.co.in {
    # API Proxy
    handle /analyze* {
        reverse_proxy trading-api:8000
    }

    # Frontend Proxy
    handle {
        reverse_proxy trading-frontend:80
    }

    encode gzip
}
