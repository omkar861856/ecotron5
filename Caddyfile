ecotron.co.in, www.ecotron.co.in {
    # Use internal self-signed certs to work with Cloudflare Proxy in 'Full' mode
    tls internal
    
    reverse_proxy app:3000
    
    # Enable Gzip compression
    encode gzip
    
    # Log configuration
    log {
        output file /data/access.log
    }
}
