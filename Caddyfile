ecotron.co.in, www.ecotron.co.in {
    # Using internal certs for Cloudflare "Full" mode
    tls internal
    
    reverse_proxy app:3000
    encode gzip
    log {
        output file /data/access.log
    }
}

trading.ecotron.co.in {
    # Using internal certs for Cloudflare "Full" mode
    tls internal
    
    # API Proxy
    handle /analyze* {
        reverse_proxy trading-api:8000
    }

    # Frontend Proxy
    handle {
        reverse_proxy trading-frontend:80
    }

    encode gzip
    log {
        output file /data/trading_access.log
    }
}
